# Godot engine binary (downloaded reproducibly by tools/fetch_godot.sh).
# The binary itself is never committed, only the fetch script and VERSION.
/tools/godot/Godot_*
/tools/godot/godot

# Godot editor / import caches.
.godot/
*.import

# Exported build output (produced by the Windows export, uploaded as a CI
# artifact; never committed).
/build/

# NOTE: export_presets.cfg IS committed. It is the project's Windows export
# configuration that the CI playtest job depends on, not machine-specific state.

# OS / editor cruft.
.DS_Store
Thumbs.db
*.swp

# Python bytecode / caches (tools/art/ and test/art/ are Python).
__pycache__/
*.py[cod]
