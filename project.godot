; Engine configuration file for the longwalk project.
; Godot 4.3-stable. See tools/godot/VERSION for the pinned engine version.
;
; This file is the standard Godot project descriptor. `scenes/main.tscn` is a
; placeholder until the title screen, character creation, and starter town
; land in a later dispatch (see ROADMAP.md, "M3: starter-town prototype").
; The prior runtime procedural world (macro map generator, walkable 3D
; world) is parked under src/legacy_procedural/, see its README.md.

config_version=5

[application]

config/name="longwalk"
config/description="Isometric / top-down 2.5D persistent-world RPG. Starter-town prototype in progress."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3")
run/disable_stdout=false

[rendering]

; gl_compatibility (OpenGL) rather than Forward+/Vulkan: it keeps headless CLI
; runs lightweight and maximizes compatibility for the downloadable Windows
; playtest build across varied GPUs.
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
