; Engine configuration file for the longwalk project.
; Godot 4.3-stable. See tools/godot/VERSION for the pinned engine version.
;
; This file is the standard Godot project descriptor. It is intentionally
; minimal for M1 (macro map generator only). There is no main scene yet
; because M1 runs headless as a CLI tool, not as a windowed game.

config_version=5

[application]

config/name="longwalk"
config/description="Procedural planet-scale exploration game. M1: macro planet map generator."
config/features=PackedStringArray("4.3")
run/disable_stdout=false

[rendering]

; Keep rendering config conservative so headless CLI runs stay lightweight.
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
