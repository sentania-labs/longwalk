; Engine configuration file for the longwalk project.
; Godot 4.3-stable. See tools/godot/VERSION for the pinned engine version.
;
; This file is the standard Godot project descriptor. The boot flow is
; title screen -> character creation -> starter town (see ROADMAP.md, "M3:
; starter-town prototype"). The prior runtime procedural world (macro map
; generator, walkable 3D world) is parked under src/legacy_procedural/, see
; its README.md.

config_version=5

[application]

config/name="longwalk"
config/description="Isometric / top-down 2.5D persistent-world RPG. Starter-town prototype."
run/main_scene="res://scenes/title_screen.tscn"
config/features=PackedStringArray("4.3")
run/disable_stdout=false

[autoload]

GameState="*res://src/sim/game_state.gd"
DisplaySettings="*res://src/render/display_settings.gd"

[display]

; Base viewport the UI and world are authored against. Everything scales from
; here; see stretch/mode below.
window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true

; The ruled art model is a 16 px pack grid enlarged by an exact 8x to the
; 128 px world tile. Render to the authored 1280x720 viewport and preserve hard
; pixel edges when it is scaled to the window.
window/stretch/mode="viewport"

; keep, not expand: the whole windowed resolution list is 16:9, so the intended
; framing holds at every offered size, and an arbitrary drag-resize letterboxes
; rather than distorting the sprites or handing the player a wider view of the
; world than the town was laid out for.
window/stretch/aspect="keep"

[input]

toggle_fullscreen={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194342,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":true,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194309,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
	]
}
zoom_in={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":0,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":4,"canceled":false,"pressed":false,"double_click":false,"script":null)
]
}
zoom_out={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":0,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":5,"canceled":false,"pressed":false,"double_click":false,"script":null)
]
}


[rendering]

textures/default_filters/use_nearest_mipmap_filter=false
textures/canvas_textures/default_texture_filter=0

; gl_compatibility (OpenGL) rather than Forward+/Vulkan: it keeps headless CLI
; runs lightweight and maximizes compatibility for the downloadable Windows
; playtest build across varied GPUs.
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
